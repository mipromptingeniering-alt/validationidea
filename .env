# ============================================
# CHET THIS - CONFIGURACIÓN DE ENTORNO
# ============================================

# === API KEYS OBLIGATORIAS ===
# Groq API (obligatorio para generación de ideas)
GROQ_API_KEY=tu_groq_api_key_aqui

# === API KEYS OPCIONALES (Trend Hunter) ===
# Apify Token (para AnswerThePublic real)
# Si no está configurado, usa datos simulados
APIFY_TOKEN=

# Twitter API (para trending topics reales)
# Si no está configurado, usa datos simulados
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# === CONFIGURACIÓN CACHE ===
# Horas antes de expirar cache de trends (default: 6)
TRENDS_CACHE_HOURS=6

# Horas antes de permitir nueva ejecución workflow (default: 24)
WORKFLOW_CACHE_HOURS=24

# === CONFIGURACIÓN GENERADOR ===
# Intentos máximos para generar idea única (default: 5)
MAX_GENERATION_ATTEMPTS=5

# Score mínimo viral para priorizar (default: 70)
MIN_VIRAL_SCORE=70

# === PATHS ===
IDEAS_FILE=data/ideas.json
TRENDS_FILE=data/viral-trends.json
CACHE_FILE=data/cache.json

# === DEBUG ===
# Habilitar modo verbose (true/false)
DEBUG_MODE=false
